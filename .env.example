# Copiar este archivo como .env y completar los valores

# Path al archivo de Service Account de Firebase
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ID del proyecto Firebase
FIREBASE_PROJECT_ID=distry-creditos-nwkenxy

# Directorio donde se guardan los archivos de sesión de Baileys
SESSION_DIR=./baileys-auth

# Nivel de log: trace | debug | info | warn | error
LOG_LEVEL=info

# Intervalo de polling de la cola en milisegundos (default: 30000 = 30s)
POLL_INTERVAL_MS=30000

# Intervalo de heartbeat en milisegundos (default: 25000 = 25s)
HEARTBEAT_INTERVAL_MS=25000
